{
    "permissions": {
        "defaultMode": "plan",
        "allow": [
            "Bash(npm install)",
            "Bash(npm install*)",
            "Bash(npm ci)",
            "Bash(npm test*)",
            "Bash(npm run lint*)",
            "Bash(npx tsc --noEmit*)",
            "Bash(npx vitest*)",
            "Bash(git status)",
            "Bash(git diff*)",
            "Bash(git log*)",
            "Bash(git add*)",
            "Bash(git commit*)",
            "Read(./**)",
            "Edit(src/**)",
            "Write(src/**)",
            "Edit(docs/**)",
            "Write(docs/**)",
            "Edit(WORKPLAN.md)",
            "Write(WORKPLAN.md)"
        ],
        "deny": [
            "Read(./.env*)",
            "Read(./.stenod/token)",
            "Read(./.stenod/**)",
            "Bash(rm -rf*)",
            "Bash(git push --force*)",
            "Bash(git reset --hard*)",
            "Bash(npm publish*)",
            "Bash(curl*)",
            "Bash(wget*)"
        ]
    }
}