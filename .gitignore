# Ignore Python virtual environments
backend/venv/
venv/

# Ignore environment variables and secrets
backend/.env
.env
.env.local

# Ignore Python cache and build artifacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
backend/.pytest_cache/
**/dist/
**/build/
**/*.egg-info/

# Ignore database files and local DB stores
backend/chroma_db/
chroma_db/
backend/*.db
*.db
*.sqlite3

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore reference documents, workplans, devlogs, and instructions
/workflow.md
/docs.md
/DEVLOG.md
/suggestedUseOfModel.md
/*.md
!/README.md
