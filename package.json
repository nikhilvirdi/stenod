{
  "name": "steno-daemon",
  "version": "0.1.0",
  "description": "Local, deterministic, out-of-band session capture daemon for AI-assisted coding.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stenod": "dist/cli/bin.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-worker-assets.mjs",
    "test": "vitest run",
    "lint": "eslint src",
    "format:check": "prettier --check src",
    "format:write": "prettier --write src",
    "prepublishOnly": "npm run build",
    "evaluate": "npm run build && node dist/evaluation/run-eval.js"
  },
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chokidar": "5.0.0",
    "clipboardy": "^5.3.1",
    "commander": "^15.0.0",
    "gpt-tokenizer": "^2.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "mockttp": "^4.4.2",
    "node-forge": "^1.4.0",
    "node-pty": "1.1.0",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.10"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.9",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.10"
  }
}
